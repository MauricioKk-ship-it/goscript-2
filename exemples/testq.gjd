struct User {
    name: string
    age: int
}

fn create_user(name: string, age: int): User {
    ret new User{
        name: name,
        age: age
    }
}

fn get_name(user: User): string -> user.name

fn main() {
    muts u = create_user("Alice", 30)
    println("Name: " + get_name(u))
    
    u.age = 31
    println("New age: " + u.age)
    
    ret 0
}

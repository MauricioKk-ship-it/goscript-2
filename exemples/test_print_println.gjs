fn main() {
    lt a = 10
    lt b = 3.14
    lt c = "Hello"
    lt d = true
    lt e = nil

    lt sum = a + b
    lt diff = a - b
    lt prod = a * b
    lt quot = a / b
    lt mod = a % b

    print("Hello ")
    println("World!")
    println(42)
    println(true)
    println("a = " + a)
    
    ret 0
}
